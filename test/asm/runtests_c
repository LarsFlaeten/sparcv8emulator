testlist="fop"

for testname in $testlist
do
    if [ "$1" != "nc" ] 
    then
        ./compile_c $testname nowarn
    fi

    if ../sparc_iss -f ${testname}.aout
    then
        echo "Test '$testname' passed."
    else
        echo "Test $testname failed! ***"
    fi
done
